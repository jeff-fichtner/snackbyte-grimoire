# Grimoire — LOCAL development config. Copy to `.env.local` and fill in.
#
# Local config layout — one file per environment, never a single ambiguous `.env`:
#
#   .env.local     <- THIS FILE, by hand. Local Postgres + a dev bot. No cloud secret.
#   .env.staging   <- GENERATED:  scripts/pull-env.sh staging   (projects grimoire-staging-*)
#   .env.prod      <- GENERATED:  scripts/pull-env.sh prod       (projects grimoire-prod-*)
#
# All three are gitignored. Pick the target explicitly every time — there is no default:
#
#   node --env-file=.env.local   scripts/migrate.mjs
#   node --env-file=.env.staging scripts/seed-dev.mjs
#   node --env-file=.env.prod    scripts/migrate.mjs
#
# Everything below is PLATFORM config: one value serves every tenant. If a second tenant would
# need a different value, it is data and belongs in the store (a row), not this file.

# Local Postgres started by `npm run db:up` (scripts/db.mjs). NOT a cloud database — that is
# the point of .env.local. To operate a cloud tier, generate .env.staging / .env.prod instead.
DATABASE_URL=postgresql://postgres@localhost:55432/grimoire

# HTTP port the local server listens on.
PORT=8080

# pino level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# A DEV Discord application's bot token — the one that posts to the dev server, never prod.
# Platform config, but nothing reads it directly: it is named by `applications.token_ref` and
# reached only through `getRest(applicationId)`, so identity stays a lookup rather than an
# ambient a second application would have to fight.
DISCORD_BOT_TOKEN=

# NOTE: operator credentials (e.g. a personal CLICKUP_API_TOKEN for managing webhooks) do NOT
# belong here — that is not platform config the app reads. Keep them in ~/.config/ instead.

# FACES (spec 002): to MINT a face the bot must hold Manage Webhooks in the target guild
# (View Channel + Send Messages + Manage Webhooks). ADOPT and post-through need no extra
# permission — a webhook URL is its own authority. Provision faces with:
#   node scripts/provision-face.mjs <mint|adopt|list|rename|delete>   (see the file header)
