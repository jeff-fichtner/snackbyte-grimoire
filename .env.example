# Grimoire — platform configuration.
#
# Everything here is PLATFORM config: one value serves every tenant. The decisive test is
# the constitution's — if a second tenant would need a different value, it is data and
# belongs in the store, not in this file. Tenant signing secrets, destinations, and spells
# are rows; none of them appear here, and adding one must never require a deploy.
#
# Every variable below is REQUIRED. There are no fallback defaults: a missing value fails
# loudly at startup naming the variable, rather than booting into wrong behaviour.

# Postgres connection string for the store.
DATABASE_URL=postgresql://user:password@host:5432/grimoire

# HTTP port the service listens on. Cloud Run injects this.
PORT=8080

# pino level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# The Discord application's bot token.
#
# This is platform config — no second tenant needs a different value — but NOTHING reads
# this variable directly. It is named by `applications.token_ref` and reached only through
# `getRest(applicationId)`. The constraint is about the seam, not the storage: identity
# must be a lookup so a second application (a tenant's own, or one connection of a sharded
# pool) is a row rather than a change at every call site. Storage can move later without
# touching a caller; the lookup cannot be added later without touching all of them.
DISCORD_BOT_TOKEN=
