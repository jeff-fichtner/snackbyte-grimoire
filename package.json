{
  "name": "snackbyte-grimoire",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Grimoire \u2014 spells for your community: performative speech for chat platforms",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "start": "node dist/server/main.js",
    "db:up": "node scripts/db.mjs up",
    "db:down": "node scripts/db.mjs down",
    "db:status": "node scripts/db.mjs status",
    "db:reset": "npm run db:up && npm run migrate && npm run seed:dev",
    "migrate": "node scripts/migrate.mjs",
    "seed:dev": "node scripts/seed-dev.mjs",
    "lint": "eslint .",
    "format": "prettier --config config/.prettierrc.json --ignore-path config/.prettierignore --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --config config/.prettierrc.json --ignore-path config/.prettierignore --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "TEST_DATABASE_URL=${TEST_DATABASE_URL:-postgresql://postgres@localhost:55432/grimoire} vitest run --no-file-parallelism tests/integration/walk.e2e.test.ts tests/integration/faces.e2e.test.ts",
    "check:all": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "spec:html": "spec-render",
    "spec:html:watch": "spec-render --watch",
    "spec:html:clean": "spec-render --clean",
    "build:server": "tsc -p tsconfig.build.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@snackbyte/spec-render": "^0.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.1",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "react": "19.2.8",
    "react-dom": "19.2.8"
  }
}
